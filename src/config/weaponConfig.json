  "property_entries": {
    "弹药": {
      "name": "弹药",
      "description": "你可以使用具有弹药属性的武器发动一次远程攻击，前提是你必须先拥有与该武器相对应的弹药。所需弹药的类型会标注在武器表的射程数据后。每次攻击消耗一发弹药。取出弹药是攻击的一部分（你需要一只空着的手来装填单手武器）。战斗结束后，你可以花费 1 分钟寻回你在战斗中使用的弹药的一半（向下取整），其余的弹药将丢失。"
    },
    "灵巧": {
      "name": "灵巧",
      "description": "使用灵巧武器进行攻击时，你可以选择使用力量或敏捷调整值进行攻击检定和伤害掷骰。你必须为这两次掷骰使用相同的调整值。"
    },
    "重型": {
      "name": "重型",
      "description": "如果你使用的是近战武器且力量值未达到 13，或者使用的是远程武器且敏捷值未达到 13，那么你使用重型武器发动的攻击检定具有劣势。"
    },
    "轻型": {
      "name": "轻型",
      "description": "当你在自己回合执行攻击动作并使用轻型武器攻击时，你可以在同一回合中以附赠动作发动一次额外攻击。该额外攻击必须使用另一把不同的轻型武器进行，并且你无法在这次额外攻击的伤害中加入你的属性调整值，除非调整值为负数。"
    },
    "装填": {
      "name": "装填",
      "description": "无论你通常能发动多少次攻击，当你使用装填武器以动作、附赠动作或反应射击时只能发射一枚弹药。"
    },
    "射程": {
      "name": "射程",
      "description": "具有射程属性的武器在弹药或投掷属性后会列出射程。射程列出的两个数字中，第一个是武器的常规射程（以尺为单位），第二个是武器的最大射程。攻击超出常规射程的目标时，你的攻击检定将具有劣势。你不能攻击超出最大射程的目标。"
    },
    "触及": {
      "name": "触及",
      "description": "你使用触及武器攻击时的触及距离增加 5 尺，这也适用于使用该武器借机攻击的触及距离。"
    },
    "投掷": {
      "name": "投掷",
      "description": "如果武器具有投掷属性，你可以将该武器投掷出去进行远程攻击，并且你可以将拔出该武器作为这次攻击的一部分。如果该武器是近战武器，则使用与近战攻击相同的属性调整值进行攻击和伤害掷骰。"
    },
    "双手": {
      "name": "双手",
      "description": "使用双手武器攻击时需要使用两只手。"
    },
    "两用": {
      "name": "两用",
      "description": "两用武器可以用一只手或两只手使用。括号中的伤害数值表示当你用双手持握武器发动近战攻击时武器造成的伤害。"
    }
  },
  "mastery_entries": {
    "顺劈": {
      "name": "顺劈",
      "description": "如果使用该武器的近战攻击检定命中生物，你可以使用该武器对首要目标 5 尺内且同样位于你触及距离中的第二个生物发动一次近战攻击检定。命中时，第二个生物受到武器的伤害，但不能在伤害中加上你的属性调整值，除非该调整值为负数。你每回合只能发动一次这样的额外攻击。"
    },
    "划伤": {
      "name": "划伤",
      "description": "即使你用该武器对生物的攻击检定失手，你仍可以对该生物造成等同于你所用属性调整值的伤害。此伤害的类型与武器造成的伤害类型相同，且伤害只能通过增加属性调整值来提高。"
    },
    "迅切": {
      "name": "迅切",
      "description": "当你发动轻型属性的额外攻击时，你可以将其作为攻击动作的一部分，而无需附赠动作。你每回合只能发动一次这样的额外攻击。"
    },
    "推离": {
      "name": "推离",
      "description": "如果你用该武器命中大型或更小的生物，你可以将该生物向远离你自身的方向沿直线推开至多 10 尺。"
    },
    "削弱": {
      "name": "削弱",
      "description": "如果你用该武器命中生物，你令该生物直至你的下个回合开始前，发动的下一次攻击检定具有劣势。"
    },
    "缓速": {
      "name": "缓速",
      "description": "如果你用该武器命中生物并对其造成伤害，你可以使其速度在你的下个回合开始前降低 10 尺。即使生物被具有该属性的武器多次命中，降低的速度也不会超过 10 尺。"
    },
    "失衡": {
      "name": "失衡",
      "description": "如果你用该武器命中生物，你可以迫使该生物进行体质豁免检定（DC=8+你用于攻击检定的属性调整值+你的熟练加值）。豁免失败时，该生物陷入倒地状态。"
    },
    "侵扰": {
      "name": "侵扰",
      "description": "如果你用该武器命中生物并对其造成伤害，直到你的下个回合结束前，你对该生物的下一次攻击检定具有优势。"
    }
  }
}
